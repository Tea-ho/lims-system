<!-- resources/mappers/test/RequestInfoRepository.xml -->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lims.lims_study.domain.test.repository.RequestInfoRepository">

    <resultMap id="RequestInfoResultMap" type="RequestInfo">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="requiresApproval" column="requires_approval"/>
    </resultMap>

    <insert id="insert" parameterType="RequestInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO request_infos (title, description, requires_approval)
        VALUES (#{title}, #{description}, #{requiresApproval})
    </insert>

    <update id="update" parameterType="RequestInfo">
        UPDATE request_infos
        SET title = #{title},
            description = #{description},
            requires_approval = #{requiresApproval}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM request_infos WHERE id = #{id}
    </delete>

    <select id="findById" resultMap="RequestInfoResultMap">
        SELECT id, title, description, requires_approval FROM request_infos WHERE id = #{id}
    </select>
</mapper>